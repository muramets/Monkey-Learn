{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "outDir": "lib",
        "rootDir": "..",
        "sourceMap": true,
        "strict": true,
        "target": "es2017",
        "skipLibCheck": true,
        "resolveJsonModule": true
    },
    "compileOnSave": true,
    "include": [
        "src/**/*",
        "../src/utils/checkinCalculations.ts",
        "../src/utils/decayCalculations.ts",
        "../src/utils/groupOrderHelpers.ts",
        "../src/types/history.ts",
        "../src/types/personality.ts",
        "../src/features/innerfaces/types.ts",
        "../src/features/protocols/types.ts",
        "../src/config/iconCatalog.ts"
    ]
}
